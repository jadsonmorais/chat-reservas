# ── Docker Compose / PostgreSQL ──────────────────────────
POSTGRES_USER=aaaa
POSTGRES_PASSWORD=aaaa
POSTGRES_DB=postgres
TZ=America/Sao_Paulo

# Host do PostgreSQL:
#   Treino (docker-compose.treino.yml)  → postgres   (nome do serviço Docker)
#   Produção (docker-compose.producao.yml) → host.docker.internal  (postgres do servidor)
POSTGRES_HOST=postgres

# Connection string used by the Node.js app (points to Docker-mapped port)
DATABASE_URL=postgresql://admin:supersecretpassword@localhost:5432/postgres

# ── SerpApi (Google Flights) ─────────────────────────────
SERPAPI_KEY=48d14d3700704c4dce68ccbfa334eaa17aa308a328805c42bfd73f69ff4253d4

# ── Evolution API (WhatsApp Gateway) ─────────────────────
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua_chave_de_api_aqui
EVOLUTION_INSTANCE_NAME=tst1

# ── Server ───────────────────────────────────────────────
PORT=3001

# ── Sales Thresholds (optional overrides) ────────────────
# Prices in USD — flights below these trigger upsell suggestions
PRICE_THRESHOLD_LOW=300
PRICE_THRESHOLD_MEDIUM=600